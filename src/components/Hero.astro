---
import { Image } from 'astro:assets';
import bgImage from '../assets/img/bg.jpg';
---

<section id="home" class="relative h-screen flex items-center justify-center">
  <div class="absolute inset-0 z-0">
    <Image src={bgImage} alt="Background" class="w-full h-full object-cover" quality="high" />
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <div class="relative z-10 text-center text-white px-4">
    <h1 class="text-4xl md:text-6xl font-bold font-heading mb-4 drop-shadow-lg">
      Clínica Nova Vida
    </h1>
    <p class="text-xl md:text-2xl font-light max-w-2xl mx-auto drop-shadow-md">
      Tratamento especializado e humanizado para dependência química e alcoolismo.
    </p>
    <a
      href="https://wa.me/5519996337576"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-block bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-8 rounded-full transition-transform hover:scale-105 shadow-lg"
    >
      Fale Conosco Agora
    </a>
  </div>
</section>
